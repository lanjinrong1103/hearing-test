{
  "name": "hearing-test",
  "version": "1.0.0",
  "description": "听力测试平台",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron:start": "electron .",
    "pack:win": "electron-builder --win portable"
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-installer-windows": "^3.0.0",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.example.hearing-test",
    "productName": "听力测试平台",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/{electron,electron-builder}/**"
    ],
    "win": {
      "target": "portable"
    }
  }
}
